#X text 140 -177 $y1 -> $y1[-1] $y2 -> $y2[-1] .....;
#X text 64 -124 fexpr~ responds to the following methods;
#X text 66 -105 clear - clears all the previous input and output buffers
;
#X text 65 -91 clear x# - clears the previous values of the #th input
;
#X text 66 -78 clear y# - clears the previous values of the #th output
;
#X text 66 -32 set x# val-1 val-2 ... - sets the as many supplied values
of the #th input;
#X text 513 -21 e.g. \, set x2 3.4 0.4 sets x2[-1]=3.4 and x2[-2]=0.4
;
#X text 66 -1 set y# val-1 val-2 ... - sets the as many supplied values
of the #th input;
#X text 514 4 e.g. \, set y3 1.1 3.3 4.5 sets y3[-1]=1.1 y3[-2]=3.3
and y3[-3]=4.5;
#X text 64 -53 set val val ... - sets the first past values of each
output;
#X text 513 -58 e.g. \, set 0.1 2.2 0.4 sets y1[-1]=0.1 y2[-1]=2.2
\, and y3[-1]=0.4;
