#X text 760 -26 POLYPHONIC SAMPLER;
#X obj 853 219 sampvoice;
#X obj 1009 -47 r note;
#X obj 1009 -25 unpack 0 0 0 0 0 0 0;
#X obj 982 -2 t b f;
